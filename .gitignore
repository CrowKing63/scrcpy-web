node_modules/
jspm_packages/
.npm/
.eslintcache
.node_repl_history
yarn-error.log*
npm-debug.log*

# Logs
logs/
*.log
lerna-debug.log*

# Build artifacts
dist/
build/
out/
.next/
.nuxt/
.parcel-cache/
.cache/
.output/

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env

