.gradle/
local.properties
*.apk
*.ap_
*.dex
*.class
*.iml
.idea/
.navigation/
app/build/
bin/
gen/
proguard/
*.iws
*.ipr

# --- IDEs / Editors ---
.vscode/
.idea/
*.swp
*.swo
*.suo
.project
.settings/
.classpath

# --- OS Specific ---
.DS_Store
Thumbs.db
Desktop.ini

# --- Project Specific (Claude, Docs, etc.) ---
.claude/
CLAUDE.md
docs/

# Essential files to remain tracked
!.gitignore
