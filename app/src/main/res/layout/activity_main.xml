<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0F"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="16dp"
            android:text="SCRCPY-Web"
            android:textColor="#00E5FF"
            android:textSize="28sp"
            android:textStyle="bold" />

        <!-- Status Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardBackgroundColor="#1A1A2E"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Status row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <View
                        android:id="@+id/statusDot"
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:background="@drawable/status_dot"
                        android:backgroundTint="#9E9E9E" />

                    <TextView
                        android:id="@+id/statusText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="@string/status_idle"
                        android:textColor="#E0E0E0"
                        android:textSize="16sp" />
                </LinearLayout>

                <!-- IP Address -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/label_ip_address"
                    android:textColor="#9E9E9E"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/ipAddressText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="http://—"
                    android:textColor="#00E5FF"
                    android:textIsSelectable="true"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Action Buttons Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="#1A1A2E"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnStartServer"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="@string/btn_start_server"
                    android:textColor="#000000"
                    app:backgroundTint="#00BCD4"
                    app:cornerRadius="12dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnStopServer"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="8dp"
                    android:text="@string/btn_stop_server"
                    android:textColor="#E0E0E0"
                    android:visibility="gone"
                    app:backgroundTint="#2A2A3E"
                    app:cornerRadius="12dp"
                    app:strokeColor="#00BCD4"
                    app:strokeWidth="1dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnGrantPermission"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="8dp"
                    android:text="@string/btn_grant_permission"
                    android:textColor="#000000"
                    app:backgroundTint="#76FF03"
                    app:cornerRadius="12dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAccessibility"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="8dp"
                    android:text="Enable Accessibility Service"
                    android:textColor="#E0E0E0"
                    app:backgroundTint="#2A2A3E"
                    app:cornerRadius="12dp"
                    app:strokeColor="#9E9E9E"
                    app:strokeWidth="1dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnNotification"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="8dp"
                    android:text="Enable Notification Listener"
                    android:textColor="#E0E0E0"
                    app:backgroundTint="#2A2A3E"
                    app:cornerRadius="12dp"
                    app:strokeColor="#9E9E9E"
                    app:strokeWidth="1dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Settings Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="24dp"
            app:cardBackgroundColor="#1A1A2E"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_settings"
                    android:textColor="#E0E0E0"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <!-- Port -->
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:hint="@string/label_port"
                    app:hintTextColor="#00BCD4"
                    app:boxStrokeColor="#00BCD4"
                    app:boxBackgroundColor="#2A2A3E"
                    style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editPort"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number"
                        android:textColor="#E0E0E0"
                        android:maxLength="5" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Resolution -->
                <TextView
                    android:id="@+id/labelResolution"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/label_resolution"
                    android:textColor="#9E9E9E"
                    android:textSize="12sp" />

                <com.google.android.material.slider.Slider
                    android:id="@+id/sliderResolution"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:valueFrom="0.25"
                    android:valueTo="1.0"
                    android:stepSize="0.25"
                    app:thumbColor="#00BCD4"
                    app:trackColorActive="#00BCD4"
                    app:trackColorInactive="#2A2A3E" />

                <!-- Bitrate -->
                <TextView
                    android:id="@+id/labelBitrate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/label_bitrate"
                    android:textColor="#9E9E9E"
                    android:textSize="12sp" />

                <com.google.android.material.slider.Slider
                    android:id="@+id/sliderBitrate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:valueFrom="1.0"
                    android:valueTo="8.0"
                    android:stepSize="1.0"
                    app:thumbColor="#00BCD4"
                    app:trackColorActive="#00BCD4"
                    app:trackColorInactive="#2A2A3E" />

                <!-- FPS -->
                <TextView
                    android:id="@+id/labelFps"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/label_fps"
                    android:textColor="#9E9E9E"
                    android:textSize="12sp" />

                <com.google.android.material.slider.Slider
                    android:id="@+id/sliderFps"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:valueFrom="15.0"
                    android:valueTo="60.0"
                    android:stepSize="5.0"
                    app:thumbColor="#00BCD4"
                    app:trackColorActive="#00BCD4"
                    app:trackColorInactive="#2A2A3E" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
