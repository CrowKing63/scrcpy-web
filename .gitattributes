# Binary files — never apply line-ending conversion
*.jar    binary
*.keystore binary
*.jks    binary
*.png    binary
*.webp   binary
*.jpg    binary
*.ico    binary

# Shell scripts — always LF on all platforms
gradlew  text eol=lf

# Kotlin / Java / XML — normalize to LF
*.kt     text eol=lf
*.java   text eol=lf
*.xml    text eol=lf
*.kts    text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.md     text eol=lf
*.json   text eol=lf
*.js     text eol=lf
*.css    text eol=lf
*.html   text eol=lf
*.properties text eol=lf
